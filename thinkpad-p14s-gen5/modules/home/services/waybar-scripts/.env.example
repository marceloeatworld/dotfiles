# Bitcoin Wallet Configuration
# Copy this file to ~/.config/waybar/.env and fill with your actual zpub keys
# DO NOT commit .env to git (it's in .gitignore)

# Wallet 1
WALLET_1_ZPUB="zpub..."
WALLET_1_NAME="Main Wallet"

# Wallet 2
WALLET_2_ZPUB="zpub..."
WALLET_2_NAME="Savings"

# Wallet 3 (optional)
# WALLET_3_ZPUB="zpub..."
# WALLET_3_NAME="Cold Storage"

# Add more wallets as needed (WALLET_4, WALLET_5, etc.)
